{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "maintainers": [
    "elestirelbilinc-sketch"
  ],
  "name": "vap-mcp-server",
  "version": "1.14.1",
  "description": "VAP AI Media API MCP server for agent workflows. Connect MCP-compatible clients to VAP image, video, and music generation.",
  "author": {
    "name": "VAP AI",
    "url": "https://github.com/vapagentmedia"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vapagentmedia/vap-showcase"
  },
  "homepage": "https://api.vapagent.com",
  "documentation": "https://vapagent.com/developer/",
  "license": "MIT",
  "keywords": [
    "mcp",
    "ai",
    "media-generation",
    "image-generation",
    "video-generation",
    "music-generation",
    "media-api",
    "ai-room",
    "agent-workflows",
    "developer-tools"
  ],
  "tools": [
    {
      "name": "generate_image",
      "description": "Generate an image through VAP Media API"
    },
    {
      "name": "generate_video",
      "description": "Generate a video through VAP Media API"
    },
    {
      "name": "generate_music",
      "description": "Generate music through VAP Media API"
    },
    {
      "name": "estimate_cost",
      "description": "Get image generation cost estimate"
    },
    {
      "name": "estimate_video_cost",
      "description": "Get video generation cost estimate"
    },
    {
      "name": "estimate_music_cost",
      "description": "Get music generation cost estimate"
    },
    {
      "name": "check_balance",
      "description": "Check account balance"
    },
    {
      "name": "get_task",
      "description": "Get task status by ID"
    },
    {
      "name": "list_tasks",
      "description": "List recent tasks"
    }
  ],
  "transport": {
    "type": "streamable-http",
    "url": "https://api.vapagent.com/mcp"
  }
}
